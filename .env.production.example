# Production — rifletautomobile.be (Hostinger VPS)
# Copier vers les variables d'environnement du Docker Manager ou vers .env sur le serveur

DJANGO_SECRET_KEY=changez-moi-longue-chaine-aleatoire
DJANGO_DEBUG=False
DJANGO_ALLOWED_HOSTS=rifletautomobile.be,www.rifletautomobile.be,backend
CORS_ALLOWED_ORIGINS=https://rifletautomobile.be,https://www.rifletautomobile.be
CSRF_TRUSTED_ORIGINS=https://rifletautomobile.be,https://www.rifletautomobile.be

MYSQL_DATABASE=riflet_db
MYSQL_USER=riflet_user
# IMPORTANT : ne changez plus MYSQL_PASSWORD après le 1er déploiement sans réinitialiser le volume MySQL
MYSQL_PASSWORD=changez-moi-mot-de-passe-fort
MYSQL_ROOT_PASSWORD=changez-moi-autre-mot-de-passe-fort

ADMIN_USERNAME=admin
ADMIN_PASSWORD=changez-moi
ADMIN_EMAIL=rifletautomobile@gmail.com

NUXT_PUBLIC_SITE_URL=https://rifletautomobile.be
NUXT_PUBLIC_API_BASE=https://rifletautomobile.be
# Ne pas mettre localhost ici en prod — le client utilise /api en same-origin

CONTACT_EMAIL=hoyouxadrien@gmail.com
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=465
EMAIL_USE_TLS=False
EMAIL_USE_SSL=True
EMAIL_HOST_USER=hoyouxadrien@gmail.com
EMAIL_HOST_PASSWORD=
DEFAULT_FROM_EMAIL=hoyouxadrien@gmail.com

GOOGLE_PLACES_API_KEY=

# seed_data : exécuté automatiquement au démarrage du conteneur backend.
#
# Reconstruction complète sans supprimer le projet hPanel (SSH) :
#   docker stop/rm conteneurs → docker volume rm → Update dans Docker Manager
# Voir README.md section "Reconstruction complète", méthode B
